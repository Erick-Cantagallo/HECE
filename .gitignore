# ==========================================
# HECE Project .gitignore
# ==========================================

# Environments
.venv/
venv/
env/
ENV/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Pytest / Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Distribution / Packaging
dist/
build/
*.egg-info/
*.egg
hece.egg-info/

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# Project Specific (Optional: ignore test reports if any)
reports/
!reports/.gitkeep